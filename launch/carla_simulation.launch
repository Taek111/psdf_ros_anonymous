<launch>
    <!-- CARLA simulation bringup: ros_bridge, ego spawn, map generation, LiDAR->LaserScan, Twist→Ackermann bridge, optional TF -->
    <!-- Arguments -->
    <arg name='role_name' default='ego_vehicle'/>
    <arg name="vehicle_filter" default='vehicle.*'/>
    <arg name="spawn_point" default='285.600006,243.729996,0.5,0.0,0.0,-90.0'/>
    <!-- Map to load on startup (either a predefined CARLA town (e.g. 'Town01'), or a OpenDRIVE map file) -->
    <arg name="town" default='Town04_Opt'/>
    <!-- Use internal TF from ros_bridge by default; enable custom TF via CARLA API if needed -->
    <arg name="use_carla_localization" default="false"/>

    <!-- Use CARLA /clock for all nodes -->
    <param name="/use_sim_time" value="true"/>

    <!-- CARLA Connection -->
    <arg name='host' default='localhost'/>
    <arg name='port' default='2000'/>
    <arg name='timeout' default='60'/>

    <!-- 1) CARLA ROS Bridge -->
    <include file="$(find carla_ros_bridge)/launch/carla_ros_bridge.launch">
        <arg name='host' value='$(arg host)'/>
        <arg name='port' value='$(arg port)'/>
        <arg name='town' value='$(arg town)'/>
        <arg name='timeout' value='$(arg timeout)'/>
    </include>

    <!-- 2) Ego vehicle spawn (controlled by agent e.g. carla_ad_agent) -->
    <include file="$(find carla_spawn_objects)/launch/carla_example_ego_vehicle.launch">
        <arg name="objects_definition_file" value='$(find psdf_ros)/config/carla_objects.json'/>
        <arg name='role_name' value='$(arg role_name)'/>
        <arg name="spawn_point_ego_vehicle" value="$(arg spawn_point)"/>
        <arg name="spawn_sensors_only" value="false"/>
    </include>

    <!-- 3) PSDF-ROS map generation (spawn static vehicles, unload layers) -->
    <node pkg="psdf_ros" type="carla_map_generation.py" name="carla_map_generation" output="screen">
        <param name="host" value="$(arg host)"/>
        <param name="port" value="$(arg port)"/>
        <param name="unload_parked_layer" value="true"/>
        <param name="num_static" value="4"/>
        <param name="exit_after_spawn" value="true"/>
        <param name="world_ready_timeout" value="30.0"/>
    </node>

    <!-- 4) PointCloud2 → LaserScan (for 2D planners) -->
    <node pkg="pointcloud_to_laserscan" type="pointcloud_to_laserscan_node" name="pointcloud_to_laserscan">
        <remap from="cloud_in" to="/carla/ego_vehicle/lidar"/>
        <remap from="scan" to="/scan"/>
        <rosparam>
            target_frame: ego_vehicle # Leave disabled to output scan in pointcloud frame
            transform_tolerance: 0.01
            min_height: 0.5
            max_height: 2.0

            angle_min: -3.1416 # -M_PI
            angle_max: 3.1416 # M_PI
            angle_increment: 0.0087 # M_PI/360.0 (~0.5 deg)
            scan_time: 0.3333
            range_min: 0.01
            range_max: 80.0
            use_inf: false
            inf_epsilon: 1.0

            # Concurrency level, affects number of pointclouds queued for processing and number of threads used
            # 0 : Detect number of cores
            # 1 : Single threaded
            # 2->inf : Parallelism level
            concurrency_level: 1
        </rosparam>
    </node>

    <!-- 6) Optional: CARLA API-based TF (map -> ego_vehicle). Disable if ros_bridge TF is used -->
    <group if="$(arg use_carla_localization)">
        <node pkg="psdf_ros" type="carla_localization.py" name="carla_localization" output="screen">
            <param name="host" value="$(arg host)"/>
            <param name="port" value="$(arg port)"/>
            <param name="role_name" value="ego_vehicle"/>
            <param name="map_frame" value="map"/>
            <param name="base_frame" value="ego_vehicle"/>
            <param name="publish_rate" value="20.0"/>
        </node>
    </group>

</launch>