<?xml version="1.0"?>
<launch>

<!-- Parameters -->
  <arg name="config_dir" default="$(find psdf_ros)/config" />

<!-- PSDF-ROS Service Node -->
  <node name="psdf_ros_node" pkg="psdf_ros" type="psdf_ros_node.py" output="screen">
    <param name="robot_footprint" value="$(arg config_dir)/robot_footprint.yaml" />
    
    <!-- MPC Parameters -->
    <param name="horizon" value="15" />
    <param name="dt" value="0.1" />
    <param name="d_safe" value="0.05" />
    
    <!-- Control limits -->
    <param name="vmin" value="-0.5" />
    <param name="vmax" value="0.5" />
    <param name="omegamin" value="-1.2" />
    <param name="omegamax" value="1.2" />
    
    <!-- Cost weights -->
    <rosparam param="Q">[50.0, 50.0, 1.0]</rosparam>
    <rosparam param="R">[0.2, 0.05]</rosparam>
    <param name="terminal_weight" value="1.0" />
    
    <!-- Safety parameters -->
    <param name="max_clusters" value="20" />
    <param name="max_edges_per_cluster" value="64" />
    <param name="emergency_stop_on_fail" value="true" />
    <param name="service_timeout" value="2.0" />
    
    <!-- Topics and frames -->
    <param name="obstacle_topic" value="/detected_edges" />
    <param name="line_segment_topic" value="/line_segments" />
    <param name="robot_base" value="base_link" />
    <param name="global_frame" value="odom" />
  </node>
</launch>
