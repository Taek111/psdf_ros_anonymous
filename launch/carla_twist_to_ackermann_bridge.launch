<launch>
  <!-- Parameters -->
  <arg name="role_name" default="ego_vehicle" />
  <arg name="speed_scale" default="1.0" />
  <arg name="steering_scale" default="1.0" />
  <arg name="steering_min" default="1.4" />
  <arg name="steering_max" default="-1.4" />
  <arg name="default_accel" default="0.0" />
  <arg name="default_jerk" default="0.0" />

  <!-- Twist → Ackermann bridge -->
  <node pkg="psdf_ros" type="twist_to_ackermann.py" name="twist_to_ackermann_$(arg role_name)" output="screen">
    <param name="role_name" value="$(arg role_name)" />
    <param name="input_topic" value="/carla/$(arg role_name)/twist" />
    <param name="output_topic" value="/carla/$(arg role_name)/ackermann_cmd" />
    <param name="speed_scale" value="$(arg speed_scale)" />
    <param name="steering_scale" value="$(arg steering_scale)" />
    <!-- Optional steering limits; empty string disables clipping (handled in node) -->
    <param name="steering_min" value="$(arg steering_min)" />
    <param name="steering_max" value="$(arg steering_max)" />
    <param name="default_accel" value="$(arg default_accel)" />
    <param name="default_jerk" value="$(arg default_jerk)" />
  </node>

  <!-- Include CARLA Ackermann control node -->
  <include file="$(find carla_ackermann_control)/launch/carla_ackermann_control.launch">
    <arg name="role_name" value="$(arg role_name)" />
  </include>
</launch>
