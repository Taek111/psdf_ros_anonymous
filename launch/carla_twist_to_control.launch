<launch>
  <!-- Parameters -->
  <arg name="role_name" default="ego_vehicle" />

  <!-- Twist → AckermannDrive bridge -->
  <!-- <include file="$(find carla_twist_to_control)/launch/carla_twist_to_control.launch">
    <arg name="role_name" value="$(arg role_name)" />
  </include> -->
  <node name="twist_to_ackermann" pkg="psdf_ros" type="twist_to_ackermann.py" output="screen">
    <param name="role_name" value="$(arg role_name)" />
    <param name="speed_scale" value="1.0" />
    <param name="steering_scale" value="1.0" />
    <param name="steering_min" value="1.4" />
    <param name="steering_max" value="-1.4" />
  </node>

  <!-- Include CARLA Cruise control node -->
  <node name="carla_cruise_controller" pkg="psdf_ros" type="carla_cruise_controller.py" output="screen">
    <param name="topic_status" value="/carla/ego_vehicle/vehicle_status"/>
    <param name="topic_cmd" value="/carla/ego_vehicle/vehicle_control_cmd"/>
    <param name="topic_cruise_cmd" value="/carla/ego_vehicle/ackermann_cmd"/>
    <param name="rate_hz" value="30"/>
    <param name="Kp" value="0.4"/>
    <param name="Ki" value="0.3"/>
    <param name="int_limit" value="0.6"/>
    <param name="ff_a0" value="0.10"/>
    <param name="ff_a1" value="0.005"/>
    <param name="ff_a2" value="0.0"/>
    <param name="max_steer_rad" value="1.4"/>
    <param name="steer_gain" value="1.0"/>
  </node>
</launch>
