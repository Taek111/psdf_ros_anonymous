<?xml version="1.0"?>
<launch>
  <!-- Simple test launch for PSDF-ROS node only -->
  
  <!-- PSDF-ROS Node -->
  <group ns="robot">
    <node name="psdf_ros_node" pkg="psdf_ros" type="psdf_ros_node.py" output="screen">
      <!-- Load robot footprint -->
      <rosparam file="$(find psdf_ros)/config/robot_footprint.yaml" command="load" />
      
      <!-- Load PSDF local planner parameters -->
      <rosparam file="$(find psdf_ros)/config/psdf_local_planner.yaml" command="load" />
      
      <!-- MPC parameters -->
      <param name="horizon" value="10" />
      <param name="dt" value="0.1" />
      <param name="max_linear_velocity" value="0.5" />
      <param name="max_angular_velocity" value="1.0" />
      <param name="learning_rate" value="0.1" />
      <param name="max_iterations" value="50" />
      <param name="tolerance" value="1e-3" />
      
      <!-- Cost weights -->
      <rosparam param="Q">[50.0, 50.0, 1.0]</rosparam>
      <rosparam param="R">[0.2, 0.05]</rosparam>
      <param name="terminal_weight" value="1.0" />
      
      <!-- Safety parameters -->
      <param name="max_clusters" value="20" />
      <param name="max_edges_per_cluster" value="64" />
      <param name="emergency_stop_on_fail" value="true" />
      <param name="service_timeout" value="0.2" />
      
      <!-- Topics and frames -->
      <param name="obstacle_topic" value="/detected_edges" />
      <param name="frame_id/local_frame" value="odom" />
    </node>
  </group>
  
  <!-- Test node -->
  <test test-name="test_psdf_service" pkg="psdf_ros" type="test_psdf_service.py" time-limit="60.0" />
  
</launch>
